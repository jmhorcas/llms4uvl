features
	AAFMFramework
		mandatory
			System
				alternative
					Linux
					Win
		optional
			Packages
				optional
					python_sat
					pycosat
					pyGlucose
					pyPicosat
			Solvers
				or
					MiniSAT
					PicoSAT
					Glucose

constraints
	MiniSAT => python_sat
	PicoSAT => pycosat | pyPicosat
	Glucose => python_sat | pyGlucose
	Win => !pyPicosat
