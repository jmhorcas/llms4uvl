namespace AIAssistant

features
	AIAssistant {abstract}
		mandatory
			Model {abstract}
				alternative
					GPT4o
						{cost 8, tokens "128k"}
					Gemini
						{cost 10, tokens "1M"}
					Claude
						{cost 9, tokens "200k"}
			Plan {abstract}
				alternative
					Free
						{monthLimit 50}
					Premium
						{monthLimit 1000}
			Access {abstract}
				or
					WebApp
					API
						{cost 2}
		optional
			FineTuning
				{cost 5}
			Temperature
				{value Integer}
			ImageGeneration
			WebSearch

constraints
	ImageGeneration => GPT4o | Gemini
	API => !WebSearch
	FineTuning <=> Premium
	Temperature.value >= 0
	Temperature.value <= 5
	sum(cost) < 15