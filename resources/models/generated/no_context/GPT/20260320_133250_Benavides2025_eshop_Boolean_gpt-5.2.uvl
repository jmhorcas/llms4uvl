features
  eShop {
    mandatory
      Catalogue
      Security
    optional
      SEO
      Payment
      Platform

    Security alternative
      Standard { price = 50; }
      High { price = 100; }

    Payment alternative
      BankTransfer { price = 10; SEPA = true; }
      CreditCard { price = 20; }

    Platform or
      MobileApp
      Browser { URL = "www.uvleshop.org"; }
  }

constraints
  CreditCard => High;
  BankTransfer => !MobileApp;

attributes
  price : number;
  SEPA  : boolean;
  URL   : string;