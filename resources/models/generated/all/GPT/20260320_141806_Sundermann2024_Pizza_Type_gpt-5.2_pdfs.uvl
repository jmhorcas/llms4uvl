namespace Pizza

features
  Pizza {
    int Size
    double price
  }
    mandatory
      Base { price = 2.0 }
    mandatory
      Sauce
        alternative
          Tomato { price = 0.8 }
          CremeFraiche { price = 1.1 }

    optional
      Cheese
        or
          Mozzarella { price = 0.4 }
          Cheddar { price = 0.6 }

    optional
      Toppings
        [1..3]
          Mushrooms { price = 0.5 }
          Onion { price = 0.3 }
          Olive { price = 0.3 }
          Pineapple { price = 0.8 }

    optional
      DeliveryAddresses
        [1..10]
          Address {
            string Street
            string City
          }

constraints
  # Cross-tree constraint: Cheddar cannot be selected with Creme Fraiche
  Cheddar => !CremeFraiche

  # Size range constraint
  Size >= 20
  Size <= 60

  # Delivery constraints (only relevant if addresses are configured)
  (DeliveryAddresses => (City == "Omashu"))
  (DeliveryAddresses => (len(Street) <= 100))

  # Overall price constraint (sum of selected feature prices)
  (Base.price
   + (Tomato ? Tomato.price : 0.0)
   + (CremeFraiche ? CremeFraiche.price : 0.0)
   + (Mozzarella ? Mozzarella.price : 0.0)
   + (Cheddar ? Cheddar.price : 0.0)
   + (Mushrooms ? Mushrooms.price : 0.0)
   + (Onion ? Onion.price : 0.0)
   + (Olive ? Olive.price : 0.0)
   + (Pineapple ? Pineapple.price : 0.0)
  ) < 5.0