namespace AIAssistant

features
	AIAssistant {abstract}
		mandatory
			Model {abstract}
				alternative
					GPT4o {cost 8, tokens "128k"}
					Gemini {cost 10, tokens "1M"}
					Claude {cost 9, tokens "200k"}
			Plan {abstract}
				alternative
					Free {monthLimit 50}
					Premium {monthLimit 1000}
			Access {abstract}
				or
					WebApp
					API {cost 2}
		optional
			FineTuning {cost 5}
			Temperature
				{type "Integer", min 0, max 5}
			ImageGeneration
			WebSearch

constraints
	ImageGeneration => (GPT4o | Gemini)
	API => !WebSearch
	FineTuning <=> Premium
	// The overall sum of costs of selected features must remain below 15
	// This is expressed as an aggregate constraint:
	// GPT4o.cost * GPT4o + Gemini.cost * Gemini + Claude.cost * Claude +
	// API.cost * API + FineTuning.cost * FineTuning < 15