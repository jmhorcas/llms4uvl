features
	eShop
		mandatory
			Catalogue
			Security
				alternative
					Standard {price 50}
					High {price 100}
		optional
			SEO
			Payment
				alternative
					"Bank Transfer" {price 10, SEPA true}
					"Credit Card" {price 20}
			Platform
				or
					"Mobile App"
					Browser {URL 'www.uvleshop.org'}

constraints
	"Credit Card" => High
	!"Bank Transfer" | !"Mobile App"