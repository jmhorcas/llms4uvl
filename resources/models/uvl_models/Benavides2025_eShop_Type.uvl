features
    eShop
        mandatory
            Security
                alternative
                    High {Price 100}
                    Standard {Price 50}
            Catalogue cardinality [1..5] {Price 30}
            Integer "Items in Basket"
        optional
            SEO {Price 40}
            Payment
                alternative
                    "Bank Transfer" {Price 10, SEPA true}
                    "Credit Card" {Price 20}
            Platform
                [2..3]
                    "Desktop App" {Price 70}
                    Boolean "Mobile App" {Price 80}
                    String Browser {Price 20}
constraints
    !("Bank Transfer" & "Mobile App")
    "Credit Card" => High
    sum(Price) < 200
    "Items in Basket" > 0
    len(Browser) < 30
